# ============================================================
#  Pneuma Memory — konfiguracja
# ============================================================

PORT=3333

# ------------------------------------------------------------
#  LM Studio — lokalny backend (bez API key)
# ------------------------------------------------------------
LMSTUDIO_URL=http://localhost:1234

# Domyślny model: Gemma 4 (4B) — działa na słabych maszynach (8GB RAM)
# Alternatywy: google/gemma-4-2b-it (bardzo słabe maszyny), qwen/qwen3.5-9b
#
# Jeden model w VRAM — temperatura per rola:
#   Intuicja  t=0.1  (deterministyczny routing)
#   Kronikarz t=0.3  (spójne podsumowania)
#   Kinia     t=0.7  (kreatywne odpowiedzi)

MODEL_INTUICJA=google/gemma-4-4b-it
MODEL_KRONIKARZ=google/gemma-4-4b-it
MODEL_KINIA=google/gemma-4-4b-it

# ------------------------------------------------------------
#  Claude API — opcjonalne (Kinia w chmurze)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# System prompt — tylko dla wbudowanego UI chatu
SYSTEM_PROMPT=

DEBUG=false
